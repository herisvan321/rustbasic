# 📑 LABEL: APP CONFIGURATION
APP_NAME=RustBasic
APP_ENV=local
APP_PORT=4000
APP_HOST=127.0.0.1
# Jalankan `openssl rand -base64 32` untuk mendapatkan key baru
APP_KEY=base64:generate_your_own_key_here
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_LIMIT_REQUEST=20

# 📑 LABEL: DATABASE CONFIGURATION
# Pilihan: sqlite, mysql
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rustbasic
DB_USERNAME=root
DB_PASSWORD=

# 📑 LABEL: SESSION CONFIGURATION
# Pilihan: database, file
SESSION_DRIVER=database
